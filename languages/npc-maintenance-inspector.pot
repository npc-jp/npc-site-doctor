msgstr ""

#: includes/class-checker.php:407
msgid "create_function() — deprecated function that builds code dynamically."
msgstr ""

#: includes/class-checker.php:409
msgid "shell_exec() — executes a shell command on the server."
msgstr ""

#: includes/class-checker.php:410
msgid "passthru() — runs external commands."
msgstr ""

#: includes/class-checker.php:414
msgid "chmod() — changes file permissions. Should not appear in core files."
msgstr ""

#: includes/class-checker.php:415
msgid "error_reporting(0) — intentionally hides error output."
msgstr ""

#: includes/class-checker.php:422
msgid "Consecutive hex escapes — a common code obfuscation pattern."
