#: includes/class-checker.php:99 includes/class-checker.php:100
#: includes/class-checker.php:734
msgid "unknown"
msgstr "不明"

#: includes/class-checker.php:193
msgid "debug.log does not exist (WP_DEBUG may be disabled)."
msgstr "debug.log が存在しません（WP_DEBUG が無効の可能性）。"

#: includes/class-checker.php:265
msgid "Could not connect to WordPress.org API."
msgstr "WordPress.org API に接続できませんでした。"

#: includes/class-checker.php:275
msgid "Could not retrieve checksum data."
msgstr "チェックサムデータが取得できませんでした。"

#: includes/class-checker.php:364
msgid ""
"Suspicious code patterns (eval, base64_decode, etc.) were detected. There is "
"a high possibility of tampering, and immediate verification is required."
msgstr "不審なコードパターン（eval, base64_decode 等）が検出されました。改ざんの可能性が高いため、早急な確認が必要です。"

#: includes/class-checker.php:366
msgid ""
"Checksum mismatches were found, but no suspicious code (eval, base64_decode, "
"etc.) was detected. This is likely a normal difference caused by locale or "
"automatic WP updates."
msgstr "チェックサムのずれがありますが、不審なコード（eval, base64_decode 等）は検出されませんでした。ロケールやWP自動更新による正常な差異の可能性が高いです。"

#: includes/class-checker.php:368
msgid ""
"Core files have checksum mismatches. No suspicious code was detected, but "
"unintended changes may be present."
msgstr "コアファイルにチェックサムのずれがあります。不審なコードは検出されませんでしたが、意図しない変更の可能性があります。"

#: includes/class-checker.php:401
msgid "eval() — executes a string as PHP code. Not used in legitimate WP core."
msgstr "eval() — 文字列をPHPコードとして実行する関数。正規のWPコアでは使われない"

#: includes/class-checker.php:402
msgid "base64_decode() — often abused to hide encoded malicious code."
msgstr "base64_decode() — エンコードされた不審コードを隠すために悪用される"

#: includes/class-checker.php:403
msgid "gzinflate() — used to decompress malicious payloads."
msgstr "gzinflate() — 圧縮された悪意あるコードの解凍に使われる"

#: includes/class-checker.php:404
msgid "str_rot13() — used for code obfuscation."
msgstr "str_rot13() — コードの難読化に使われる"

#: includes/class-checker.php:406
msgid "assert() — eval-equivalent dangerous function."
msgstr "assert() — eval相当の危険な関数"

#: includes/class-checker.php:407
msgid "create_function() — deprecated function that builds code dynamically."
msgstr "create_function() — 動的にコードを生成する非推奨関数"

#: includes/class-checker.php:409
msgid "shell_exec() — executes a shell command on the server."
msgstr "shell_exec() — サーバー上でシェルコマンドを実行"

#: includes/class-checker.php:410
msgid "passthru() — runs external commands."
msgstr "passthru() — 外部コマンドの実行"

#: includes/class-checker.php:414
msgid "chmod() — changes file permissions. Should not appear in core files."
msgstr "chmod() — ファイルのパーミッション変更。コアファイルにあるべきでない"

#: includes/class-checker.php:415
msgid "error_reporting(0) — intentionally hides error output."
msgstr "error_reporting(0) — エラー表示を意図的に隠す"

#: includes/class-checker.php:422
msgid "Consecutive hex escapes — a common code obfuscation pattern."
msgstr "16進エスケープの連続 — コードの難読化によく使われるパターン"

#: includes/class-checker.php:424
msgid "Long Base64 string assignment — possible encoded malicious payload."
msgstr "長いBase64文字列の代入 — エンコードされた悪意あるコードの可能性"

#: includes/class-checker.php:426
msgid ""
"Nested variable function call — dynamic code execution obfuscation pattern."
msgstr "変数関数のネスト呼び出し — 動的コード実行の難読化パターン"

#: includes/class-checker.php:676
msgid "Site is not using HTTPS."
msgstr "サイトが HTTPS を使用していません。"

#. translators: %s: SSL error message from stream_socket_client
#: includes/class-checker.php:704
#, php-format
msgid "SSL connection failed: %s"
msgstr "SSL接続に失敗: %s"

#: includes/class-checker.php:717
msgid "Failed to parse certificate."
msgstr "証明書の解析に失敗しました。"

#: includes/class-notifier.php:34
msgid "Possible file tampering (suspicious code detected)"
msgstr "ファイル改ざんの疑い（不審コード検出）"

#: includes/class-notifier.php:44
msgid "Suspicious PHP files in uploads directory"
msgstr "uploads内に不審なPHPファイル"

